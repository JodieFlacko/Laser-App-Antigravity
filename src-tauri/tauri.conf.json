{
    "$schema": "https://schema.tauri.app/config/2",
    "productName": "VictoriaLaserApp",
    "version": "1.0.2",
    "identifier": "com.victorialaser.app",
    "build": {
        "frontendDist": "../server/public",
        "devUrl": "http://localhost:5173",
        "beforeDevCommand": "pnpm --filter web dev",
        "beforeBuildCommand": "pnpm --filter web build && pnpm --filter server build && pnpm --filter server sidecar:build"
    },
    "app": {
        "windows": [
            {
                "title": "Victoria Laser App",
                "width": 1280,
                "height": 800,
                "resizable": true,
                "fullscreen": false
            }
        ],
        "security": {
            "csp": null
        }
    },
    "bundle": {
        "active": true,
        "createUpdaterArtifacts": true,
        "targets": "all",
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/icon.icns",
            "icons/icon.ico"
        ],
        "resources": [
            "resources/server-sidecar-x86_64-pc-windows-msvc.exe",
            "resources/better_sqlite3.node",
            "resources/drizzle/**/*"
        ],
        "externalBin": [
            "resources/server-sidecar"
        ],
        "windows": {
            "wix": {},
            "nsis": {}
        }
    },
    "plugins": {
        "shell": {
            "open": false
        },
        "updater": {
            "active": true,
            "endpoints": [
                "https://github.com/JodieFlacko/Laser-App-Antigravity/releases/latest/download/latest.json"
            ],
            "dialog": true,
            "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEZGQjRCNzg4NUM5NEIwOUMKUldTY3NKUmNpTGUwL3o0S3pDS0dzRmRFcmk3bmdGNFk2N28zdjVHdmlWNDJtK3U5ZjQvNzVmYWoK"
        }
    }
}